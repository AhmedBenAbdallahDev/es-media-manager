{
  "name": "gh-auth-switcher",
  "displayName": "GitHub Auth Auto-Switcher",
  "description": "Automatically switch GitHub CLI auth and git config based on repo owner",
  "version": "1.0.6",
  "publisher": "dorra",
  "repository": {
    "type": "git",
    "url": "https://github.com/LanayruLakeDev/es-cover-manager"
  },
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "github",
    "git",
    "auth",
    "authentication",
    "account",
    "switcher"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/.git",
    "onCommand:gh-auth-switcher.switchNow",
    "onCommand:gh-auth-switcher.showStatus"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gh-auth-switcher.switchNow",
        "title": "GitHub Auth: Switch Account Now"
      },
      {
        "command": "gh-auth-switcher.showStatus",
        "title": "GitHub Auth: Show Status"
      }
    ],
    "configuration": {
      "title": "GitHub Auth Switcher",
      "properties": {
        "ghAuthSwitcher.pollInterval": {
          "type": "number",
          "default": 60000,
          "description": "Poll interval in milliseconds (default: 60s)"
        },
        "ghAuthSwitcher.accountMapping": {
          "type": "object",
          "default": {
            "AhmedBenAbdallahDev": {
              "name": "AhmedBenAbdallahDev",
              "email": "celiandorra@gmail.com"
            },
            "Celiandorra": {
              "name": "Celiandorra",
              "email": "dorrabenabdallah13@gmail.com"
            },
            "LanayruLakeDev": {
              "name": "LanayruLakeDev",
              "email": "LanayruLakeDev@email.com"
            }
          },
          "description": "Map of GitHub account login to git name/email"
        },
        "ghAuthSwitcher.enableNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications when auth is switched"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "echo 'No tests yet'"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.x",
    "@typescript-eslint/parser": "^8.x",
    "eslint": "^8.x",
    "esbuild": "^0.24.x",
    "typescript": "^5.x"
  }
}
